<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    SponsorshipHub QA Test Suite
    Run order: UserManagement → CampaignManagement (serial, preserving state within each module)
-->
<suite name="SponsorshipHub QA Suite" parallel="none" verbose="2">

    <test preserve-order="true" name="UserManagement_Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="modules.userManagement.TestScenario01"/>
        </classes>
    </test>

    <test preserve-order="true" name="CampaignManagement_Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="modules.campaignManagement.TestScenario02"/>
        </classes>
    </test>

</suite>